# ─────────────────────────────────────────────────────────────────────────────
# API keys (set the ones you need based on your model choice)
# ─────────────────────────────────────────────────────────────────────────────
# The default settings use Nebius and OpenAI.
# OPENAI_API_KEY is also used by the vision MCP tool, so it is always required.
NEBIUS_API_KEY=
OPENAI_API_KEY=

# Only needed if you switch to provider
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Custom Model Selection
# Purple agent: defaults to nebius/openai/gpt-oss-120b uncomment only if you want to use a different model
# COREBENCH_TEXT_MODEL=
# LLM-as-judge: defaults to openai/gpt-5-mini uncomment only if you want to use a different judge model
# COREBENCH_JUDGE_MODEL=

# ─────────────────────────────────────────────────────────────────────────────
# Advanced: Self-hosted models (most users can ignore this)
# Uncomment to route requests to a local OpenAI-compatible server (vLLM, Ollama, etc.)
# ─────────────────────────────────────────────────────────────────────────────
# COREBENCH_TEXT_API_BASE=http://127.0.0.1:8000/v1
# COREBENCH_TEXT_API_KEY=dummy