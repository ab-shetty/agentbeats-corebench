# ─── API Keys ───
# Default config uses Nebius (purple agent) and OpenAI (judge + vision tool).
# Both keys are required unless you override the model/provider settings below.
NEBIUS_API_KEY=your-nebius-key
OPENAI_API_KEY=sk-...

# Optional (switch provider)
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=


# ─── Model Selection Override ───
# Purple agent      (default: nebius/openai/gpt-oss-120b)
# uncomment to override
# COREBENCH_TEXT_MODEL=

# LLM-as-a-judge    (default: openai/gpt-5-mini)
# uncomment to override
# COREBENCH_JUDGE_MODEL=

# Use litellm format: "provider/model"
# Examples:
#   COREBENCH_TEXT_MODEL=openai/gpt-4o
#   COREBENCH_TEXT_MODEL=anthropic/claude-sonnet-4
#   COREBENCH_JUDGE_MODEL=gemini/gemini-3.5-flash
#   COREBENCH_JUDGE_MODEL=nebius/meta-llama/Llama-3.3-70B-Instruct


# ─── Advanced ───
# Ignore unless using a local vLLM/Ollama server
# COREBENCH_TEXT_API_BASE=http://127.0.0.1:8000/v1
# COREBENCH_TEXT_MODEL=ollama/your-model-name
# COREBENCH_TEXT_API_KEY=dummy
