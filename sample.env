# API keys (set the ones you need based on your model choice)
NEBIUS_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Model selection (uses litellm format: "provider/model")
# Default: nebius/Qwen/Qwen3-Coder-30B-A3B-Instruct
# Examples:
#   COREBENCH_TEXT_MODEL=openai/gpt-4o
#   COREBENCH_TEXT_MODEL=anthropic/claude-sonnet-4-20250514
#   COREBENCH_TEXT_MODEL=gemini/gemini-2.0-flash
#   COREBENCH_TEXT_MODEL=nebius/meta-llama/Llama-3.3-70B-Instruct
# COREBENCH_TEXT_MODEL=

# ─────────────────────────────────────────────────────────────────────────────
# Advanced: Self-hosted vLLM (most users can ignore this)
# Uncomment these to route requests to your local vLLM server
# ─────────────────────────────────────────────────────────────────────────────
# COREBENCH_TEXT_API_BASE=http://127.0.0.1:8000/v1
# COREBENCH_TEXT_API_KEY=dummy