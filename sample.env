# Required API keys
NEBIUS_API_KEY=
OPENAI_API_KEY=

# Optional: Choose a different model (default: Qwen/Qwen3-Coder-30B-A3B-Instruct)
# You can also override via CLI: --model meta-llama/Llama-3.3-70B-Instruct
# COREBENCH_TEXT_MODEL=meta-llama/Llama-3.3-70B-Instruct

# ─────────────────────────────────────────────────────────────────────────────
# Advanced: Self-hosted vLLM (most users can ignore this)
# Uncomment these to route requests to your local vLLM server instead of Nebius
# ─────────────────────────────────────────────────────────────────────────────
# COREBENCH_TEXT_API_BASE=http://127.0.0.1:8000/v1
# COREBENCH_TEXT_API_KEY=dummy
